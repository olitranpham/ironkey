# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ironkey"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Platform (Ironkey) secret key — never expose to clients
STRIPE_SECRET_KEY="sk_live_..."
# OAuth client ID from Stripe Dashboard → Connect → Settings
# Must be NEXT_PUBLIC_ so the browser can build the OAuth URL without hitting the API
STRIPE_CLIENT_ID="ca_..."
NEXT_PUBLIC_STRIPE_CLIENT_ID="ca_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Seam (smart-lock access control) ────────────────────────────────────────
SEAM_API_KEY="seam_apikey_..."

# ─── Migration (one-time) ─────────────────────────────────────────────────────
# Source database for scripts/migrate-triumph.js
OLD_DATABASE_URL="postgresql://USER:PASSWORD@old-host:5432/triumph_db"

# ─── Webhook / external integrations (Zapier etc.) ───────────────────────────
# Static long-lived secret — use in Zapier's Authorization header as "Bearer <secret>"
WEBHOOK_SECRET="generate-a-long-random-string-here"

# ─── Super-admin ──────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@ironkeyentry.com"
ADMIN_PASSWORD="your-strong-password-here"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
