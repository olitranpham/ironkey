generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Gym ──────────────────────────────────────────────────────────────────────

model Gym {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  timezone  String   @default("America/New_York")

  // Stripe – one customer per gym
  stripeCustomerId     String?
  stripeSecretKey      String?
  stripeWebhookSecret  String?
  stripeAccountId      String?   // Stripe Connect – connected account ID (acct_...)

  // Seam – smart-lock integration (optional)
  seamConnectedAccountId String?
  seamApiKey             String?
  seamDeviceId           String?

  // Zapier webhook URLs for outbound notifications
  zapierGuestWebhookUrl  String?
  zapierMemberWebhookUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          Member[]
  guestVisits      GuestVisit[]
  guestWaivers     GuestWaiver[]
  users            GymUser[]
  financialEntries FinancialEntry[]
  inventoryItems   InventoryItem[]
}

// ─── Member ───────────────────────────────────────────────────────────────────

model Member {
  id        String       @id @default(cuid())
  gymId     String
  gym       Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  email     String
  phone     String?

  status         MemberStatus   @default(ACTIVE)
  membershipType MembershipType @default(GENERAL)

  // Stripe
  stripeCustomerId     String?
  stripeSubscriptionId String?
  priceId              String?

  // Seam / smart-lock access code
  accessCode       String?
  seamDeviceId     String?

  // Freeze window (Ironkey-native)
  freezeStartDate  DateTime?
  freezeEndDate    DateTime?

  // Legacy date fields preserved from old Triumph DB
  dateAccessed DateTime?
  dateFrozen   DateTime?
  dateCanceled DateTime?
  maxFreeze    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guestVisits GuestVisit[]

  @@unique([gymId, email])
}

enum MemberStatus {
  ACTIVE
  FROZEN
  CANCELLED
  OVERDUE
}

enum MembershipType {
  FOUNDING
  GENERAL
  STUDENT
  WEEKEND
  FLEX
}

// ─── Guest ────────────────────────────────────────────────────────────────────
// Global — shared across gyms by email. Per-gym waiver records live in GuestWaiver.

model Guest {
  id         String   @id @default(cuid())

  name       String
  email      String?  @unique
  phone      String?
  accessCode String?

  passes   GuestVisit[]
  waivers  GuestWaiver[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("GuestProfile")
}

// ─── GuestVisit ───────────────────────────────────────────────────────────────
// Each individual pass purchase or check-in record.

model GuestVisit {
  id        String  @id @default(cuid())
  gymId     String
  gym       Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId  String?
  member    Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  guestProfileId String?
  guestProfile   Guest?  @relation(fields: [guestProfileId], references: [id], onDelete: SetNull)

  guestName  String
  guestEmail String?
  guestPhone String?

  passType   PassType  @default(SINGLE)
  passesLeft Int?

  usedAt    DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@map("GuestPass")
}

enum PassType {
  SINGLE
  THREE_PACK
  FIVE_PACK
  TEN_PACK
  VALUE
  DELUXE
}

// ─── GuestWaiver ──────────────────────────────────────────────────────────────
// Records that a guest has signed the waiver at a specific gym.

model GuestWaiver {
  id             String   @id @default(cuid())
  guestProfileId String
  gymId          String
  signedAt       DateTime @default(now())

  guestProfile   Guest @relation(fields: [guestProfileId], references: [id])
  gym            Gym   @relation(fields: [gymId], references: [id])

  @@unique([guestProfileId, gymId])
}

// ─── GymUser (staff / admin accounts) ────────────────────────────────────────

model GymUser {
  id       String      @id @default(cuid())
  gymId    String
  gym      Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)

  email    String
  password String      // bcrypt hash

  role     GymUserRole @default(STAFF)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gymId, email])
}

enum GymUserRole {
  OWNER
  ADMIN
  STAFF
}

// ─── FinancialEntry ───────────────────────────────────────────────────────────

model FinancialEntry {
  id          String   @id @default(cuid())
  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  type        String   // 'income' | 'expense'
  category    String
  amount      Float
  description String?
  date        DateTime

  createdAt   DateTime @default(now())

  @@index([gymId, date])
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model InventoryItem {
  id         String   @id @default(cuid())
  gymId      String
  gym        Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  name       String
  category   String
  quantity   Int      @default(0)
  lowStockAt Int      @default(5)
  unitCost   Float?
  notes      String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  logs       InventoryLog[]

  @@index([gymId])
}

model InventoryLog {
  id        String        @id @default(cuid())
  gymId     String
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  change    Int      // positive = restock, negative = sale/removal
  reason    String   // 'sale' | 'restock' | 'correction' | 'manual'

  createdAt DateTime @default(now())

  @@index([itemId])
}
